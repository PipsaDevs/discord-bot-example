{
	"name": "discord-bot-template",
	"version": "1.1.0",
	"description": "¡Un bot de Discord listo para usar!",
	"type": "module",
	"main": "src/index.ts",
	"scripts": {
		"start": "node dist/src/index.js",
		"dev": "nodemon",
		"prod": "pm2 start \"npm run start\" --name bot",
		"lint": "eslint src --fix",
		"lint:check": "eslint src",
		"format": "prettier --write src",
		"format:check": "prettier --check src",
		"build": "tsc",
		"build:watch": "tsc --watch"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/PipsaDevs/discord-bot-template.git"
	},
	"keywords": [
		"discord",
		"bot"
	],
	"author": "PipsaDevs",
	"license": "ISC",
	"bugs": {
		"url": "https://github.com/PipsaDevs/discord-bot-example/issues"
	},
	"homepage": "https://github.com/PipsaDevs/discord-bot-example#readme",
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@types/node": "^25.8.0",
		"@typescript-eslint/eslint-plugin": "^8.59.2",
		"@typescript-eslint/parser": "^8.59.2",
		"eslint": "^10.3.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-prettier": "^5.5.5",
		"globals": "^17.6.0",
		"jiti": "^2.7.0",
		"nodemon": "^3.1.14",
		"prettier": "^3.8.3",
		"ts-node": "^10.9.2",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.59.2"
	},
	"dependencies": {
		"discord.js": "^14.26.4",
		"dotenv": "^17.4.2"
	}
}
